{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "@emailjs/browser": "^4.4.0",
    "antd": "^5.22.0",
    "i18next": "^24.2.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^19.0.0",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "react-icons": "^5.4.0",
    "react-multi-carousel": "^2.8.0",
    "react-responsive": "^10.0.0",
    "react-router-dom": "^6.28.0",
    "styled-components": "^6.1.0"
  },
  "scripts": {
    "start": "vite --port 5001",
    "build": "pnpm run clean && vite build",
    "build:prod": "vite build",
    "clean": "rm -rf build",
    "preview": "vite preview --port 5001",
    "dev": "pnpm install && pnpm run start",
    "watched": "nodemon -w src --ext js --exec pnpm run build",
    "watch": "npm-watch",
    "g": "npx generate-react-cli component --",
    "p": "npx generate-react-cli component -- --type=page",
    "upload": "aws s3 sync build s3://txd-portal/",
    "flush": "aws cloudfront create-invalidation --distribution-id E1JLIDSYCZB9UH --paths \"/*\"",
    "release": "pnpm run build:prod && pnpm run upload && pnpm run flush"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^7.0.2",
    "generate-react-cli": "^8.0.0",
    "nodemon": "^3.0.0",
    "npm-watch": "^0.13.0",
    "vite": "^6.0.0",
    "vite-plugin-svgr": "^4.3.0"
  },
  "watch": {
    "build": {
      "patterns": [
        "src"
      ],
      "extensions": "js,jsx"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
